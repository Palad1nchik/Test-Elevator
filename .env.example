# Copy to .env and adjust for your environment:  cp .env.example .env

# Host port the site is published on (nginx/frontend).
WEB_PORT=8080

# Backend runtime mode: development | production
APP_ENV=production

# Browser origins allowed to call the API (CORS). For production set your domain.
# When the frontend and API share an origin via nginx, CORS is not strictly
# needed, but set this to your public URL to be safe, e.g.:
#   CORS_ORIGINS=https://kasper.kz,https://www.kasper.kz
CORS_ORIGINS=http://localhost:8080
